[Unit]
Description=Xoul Telegram Bot Client
After=xoul.service
Wants=xoul.service

[Service]
Type=simple
WorkingDirectory=/root/xoul
ExecStart=/usr/bin/python3 /root/xoul/clients/telegram_client.py
Restart=always
RestartSec=10
Environment=XOUL_CONFIG=/root/xoul/config.json

[Install]
WantedBy=multi-user.target
